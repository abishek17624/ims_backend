# ============================================================
# .gitignore — ims_backend (Express / Node.js / MySQL)
# Production-ready
# ============================================================

# ── Environment & Secrets (CRITICAL — never commit) ─────────
.env
.env.*
!.env.example
.env.local
.env.production
.env.staging
.env.development
*.pem
*.key
*.cert
*.p12
*.pfx

# ── Node / npm ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json

# ── User-uploaded Files (runtime data, not source) ──────────
uploads/*
!uploads/.gitkeep

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
combined.log
error.log

# ── Build / Compiled ─────────────────────────────────────────
dist/
build/
out/

# ── Testing ──────────────────────────────────────────────────
coverage/
.nyc_output/

# ── OS / System ──────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE & Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.swp
*~

# ── Runtime / Process ────────────────────────────────────────
*.pid
*.seed
*.pid.lock
pids/

# ── Database & Backup Files ──────────────────────────────────
*.sql
*.sqlite
*.sqlite3
*.db
Dump*/
db_backup*/

# ── Temporary ────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp

# ── PM2 / Deployment ─────────────────────────────────────────
.pm2/
ecosystem.config.js.local
